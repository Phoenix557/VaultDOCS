---
import type { HttpMethod } from '../../data/types';

interface Props {
  method: HttpMethod;
  class?: string;
}

const { method, class: className = '' } = Astro.props;

/* Method badge colors kept distinct per user preference */
const styles: Record<HttpMethod, string> = {
  GET: 'border-neutral-600 bg-transparent text-lime-400',
  POST: 'border-emerald-800/60 bg-emerald-950 text-emerald-400',
  PUT: 'border-amber-800/60 bg-amber-950/90 text-amber-400',
  PATCH: 'border-amber-800/60 bg-amber-950/90 text-amber-400',
  DELETE: 'border-neutral-600 bg-transparent text-red-400',
};
---

<span
  class:list={[
    'inline-flex shrink-0 items-center border px-2 py-0.5 font-mono text-xs font-semibold tracking-wider',
    styles[method],
    className,
  ]}
>
  {method}
</span>
