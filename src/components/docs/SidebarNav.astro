---
import type { ApiGroup, AppConfig } from '../../data/types';
import { getGuideNav } from '../../data/apps/vaultcdn/guides';
import MethodBadge from './MethodBadge.astro';

interface Props {
  mode: 'docs' | 'guides';
  app: AppConfig;
  appSlug: string;
  apiGroups?: ApiGroup[];
  currentGuideSlug?: string;
  onNavigate?: 'close-mobile' | 'none';
}

const { mode, app, appSlug, apiGroups = [], currentGuideSlug, onNavigate = 'none' } = Astro.props;
const guides = getGuideNav();
const linkClass = onNavigate === 'close-mobile' ? 'mobile-nav-link' : '';
---

{mode === 'docs' && (
  <>
    <div class="mb-4 border border-border bg-card p-3">
      <p class="font-heading text-sm font-bold tracking-widest text-white">{app.name.toUpperCase()}</p>
      <p class="mt-0.5 font-heading text-[10px] font-medium uppercase tracking-widest text-muted-foreground">
        {app.version} · REST API
      </p>
    </div>
    <nav class="flex flex-col gap-3 pb-4">
      {apiGroups.map((section) => (
        <details class="sidebar-section group" open>
          <summary class="flex cursor-pointer select-none items-center gap-2 font-heading text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:text-white/80">
            <svg
              class="sidebar-chevron h-3 w-3 shrink-0 text-muted-foreground transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span>{section.title}</span>
          </summary>
          <ul class="sidebar-section-body">
            {section.endpoints.map((ep) => (
              <li>
                <a
                  href={`#${ep.id}`}
                  class:list={[
                    'flex items-start gap-2 py-0.5 text-sm text-muted-foreground transition-colors hover:text-white',
                    linkClass,
                  ]}
                >
                  <MethodBadge method={ep.method} class="mt-0.5 px-1 py-0 text-[9px]" />
                  <span class="min-w-0 break-words leading-snug">{ep.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      ))}
      <details class="sidebar-section group" open>
        <summary class="flex cursor-pointer select-none items-center gap-2 font-heading text-xs font-semibold uppercase tracking-widest text-white transition-colors hover:text-white/80">
          <svg
            class="sidebar-chevron h-3 w-3 shrink-0 text-muted-foreground transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
          <span>Media</span>
        </summary>
        <ul class="sidebar-section-body">
          <li>
            <a
              href="#image-previews"
              class:list={[
                'block py-0.5 text-sm text-muted-foreground transition-colors hover:text-white',
                linkClass,
              ]}
            >
              Image Previews
            </a>
          </li>
        </ul>
      </details>
    </nav>
  </>
)}

{mode === 'guides' && (
  <>
    <div class="mb-4 border border-border bg-card p-3">
      <p class="font-heading text-sm font-bold tracking-widest text-white">{app.name.toUpperCase()}</p>
      <p class="mt-0.5 font-heading text-[10px] font-medium uppercase tracking-widest text-muted-foreground">
        Guides
      </p>
    </div>
    <nav class="flex flex-col gap-1 border-l border-border pb-4 pl-3">
      {guides.map((guide) => (
        <a
          href={`/${appSlug}/guides/${guide.slug}`}
          class:list={[
            'py-1 text-sm transition-colors',
            guide.slug === currentGuideSlug
              ? 'font-semibold text-white'
              : 'text-muted-foreground hover:text-white',
            linkClass,
          ]}
        >
          {guide.title}
        </a>
      ))}
    </nav>
  </>
)}

<script>
  function initSidebarSections() {
    document.querySelectorAll('.sidebar-section').forEach((section) => {
      section.querySelectorAll('a[href^="#"]').forEach((link) => {
        if (link.dataset.bound) return;
        link.dataset.bound = 'true';
        link.addEventListener('click', (e) => e.stopPropagation());
      });
    });
  }

  initSidebarSections();
  document.addEventListener('astro:page-load', initSidebarSections);
</script>
